# MiniCMD - archivos que NO deben subirse

# Python cache
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd

# Entornos virtuales
.venv/
venv/
env/
ENV/

# Variables locales / secretos
.env
.env.*
!.env.example
*.key
*.pem
*.crt
*.p12
*.pfx

# Logs
*.log
logs/

# Base de datos / runtime local
*.sqlite
*.sqlite3
*.db

# PyInstaller / builds
build/
dist/
*.spec.bak

# Pero permitir subir el spec principal si existe
!MiniCMD.spec

# Archivos temporales
*.tmp
*.temp
*.bak
*.swp
*.swo

# Sistema operativo
.DS_Store
Thumbs.db
desktop.ini

# IDEs
.idea/
*.code-workspace

# Node / frontend si luego usas npm
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Coverage / tests
.coverage
htmlcov/
.pytest_cache/

# No ignorar carpetas importantes del cliente
!web/
!web/**
!commads/
!commads/**
!system/
!system/**
